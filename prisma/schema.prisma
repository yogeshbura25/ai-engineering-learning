generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ChatMessage {
  id        Int      @id @default(autoincrement())
  sessionId String   @map("session_id")
  role      String
  content   String
  createdAt DateTime @default(now()) @map("created_at")

  @@index([sessionId])
  @@map("chat_messages")
}

model DocumentChunk {
  id         String   @id
  text       String
  source     String
  category   String
  chunkIndex Int      @map("chunk_index")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([category])
  @@index([source])
  @@map("document_chunks")
}
